# HAWKEYE Environment Configuration
# Copy to .env.local and fill in your values.
# Never commit .env.local to version control.

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# EVM private key (0x-prefixed). Used for 0G Compute, 0G Storage, and on-chain
# registry calls. Fund at https://faucet.0g.ai for testnet.
HAWKEYE_EVM_PRIVATE_KEY=

# ─── RECOMMENDED ─────────────────────────────────────────────────────────────

# OpenRouter API key (https://openrouter.ai). Primary LLM fallback when 0G
# Compute is unavailable. Supports any model via OPENROUTER_MODEL.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Anthropic Claude API key. Secondary LLM fallback (used only when both 0G
# Compute and OpenRouter are unavailable).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# 0G Compute model and provider (defaults to Galileo testnet values)
OG_MODEL=qwen/qwen-2.5-7b-instruct
OG_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Privy (https://privy.io). Per-user agent wallets. Without these, users must
# connect an external wallet via /wallet.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── OPTIONAL ────────────────────────────────────────────────────────────────

# Uniswap Trading API key for quote/swap routing
UNISWAP_API_KEY=

# GoPlus Security API for token safety scanning (https://docs.gopluslabs.io)
GOPLUS_API_KEY=
GOPLUS_API_SECRET=

# KeeperHub API key for MEV-protected tx submission (https://app.keeperhub.com)
KH_API_KEY=

# Dune Analytics API key for smart money flow data
DUNE_API_KEY=

# Etherscan API key for holder concentration and contract age queries
# (Research Agent, rate-limited to 2 req/s)
ETHERSCAN_API_KEY=

# Birdeye API key for Solana token data (https://docs.birdeye.so)
BIRDEYE_API_KEY=

# Brave Search API key for trend/news signal detection
BRAVE_API_KEY=

# Tavily Search API key for deep research queries (https://tavily.com)
TAVILY_API_KEY=

# AES-256-GCM encryption key for wallet store at rest
HAWKEYE_MASTER_KEY=

# 0G Chain registry contract address (deployed via scripts/deploy-registry.ts)
HAWKEYE_REGISTRY_ADDRESS=
OG_CHAIN_ID=16602
OG_MAINNET_RPC=https://evmrpc-testnet.0g.ai

# Gensyn AXL P2P node (http://127.0.0.1:9002 when running locally)
AXL_API_URL=

# Arkham API key for enriched on-chain entity data (https://arkhamintelligence.com)
ARKHAM_API_KEY=

# Nansen API key for smart money flow data (https://docs.nansen.ai)
NANSEN_API_KEY=

# Health server port (default 8080)
HEALTH_PORT=8080

# ─── CHAIN RPC OVERRIDES (optional, Publicnode defaults are fine) ────────────

# EVM_RPC_ETHEREUM=https://ethereum-rpc.publicnode.com
# EVM_RPC_BASE=https://base-rpc.publicnode.com
# EVM_RPC_ARBITRUM=https://arbitrum-one-rpc.publicnode.com
# EVM_RPC_OPTIMISM=https://optimism-rpc.publicnode.com
# EVM_RPC_POLYGON=https://polygon-bor-rpc.publicnode.com
# EVM_RPC_BSC=https://bsc-rpc.publicnode.com
# EVM_RPC_SEPOLIA=https://ethereum-sepolia-rpc.publicnode.com
