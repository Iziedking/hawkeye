# Copy to .env.local and fill in your values. Never commit .env.local.

# GoPlus Security API (https://docs.gopluslabs.io)
GOPLUS_API_KEY=
GOPLUS_API_SECRET=

# 0G Galileo testnet wallet (0x-prefixed). Fund at https://faucet.0g.ai
HAWKEYE_EVM_PRIVATE_KEY=

# KeeperHub (https://app.keeperhub.com)
KH_API_KEY=

# OpenClaw gateway token. Auto-read from ~/.openclaw/openclaw.json if unset
OPENCLAW_GATEWAY_TOKEN=

# ── Research Agent ────────────────────────────────────────────────────────────

# Etherscan — EVM contract age + top holders (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=

# Solscan — Solana token age, holders, transfer history (https://pro-api.solscan.io)
SOLSCAN_API_KEY=

# Birdeye — enhanced Solana analytics (https://birdeye.so/developer)
BIRDEYE_API_KEY=

# Arkham Intelligence — entity labels on wallets (https://platform.arkhamintelligence.com)
ARKHAM_API_KEY=

# Brave Search — global web ×2 (general + crypto-specific domains) (https://api.search.brave.com)
BRAVE_API_KEY=

# Tavily — deep search fallback/amplifier (https://tavily.com)
TAVILY_API_KEY=

# Neynar — Farcaster search for Web3-native community signal (https://neynar.com)
NEYNAR_API_KEY=

# Stocktwits — trading community sentiment (no key required, public API)

# ── LLM Synthesis ─────────────────────────────────────────────────────────────
# LLM inference runs on 0G Compute — funded via HAWKEYE_EVM_PRIVATE_KEY (set above).
# Optional overrides (leave blank to use built-in defaults):
OG_RPC_URL=           # default: https://evmrpc-testnet.0g.ai
OG_PROVIDER_ADDRESS=  # default: 0xa48f01287233509FD694a22Bf840225062E67836
OG_MODEL=             # default: qwen/qwen-2.5-7b-instruct
