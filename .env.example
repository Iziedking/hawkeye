# Copy to .env.local and fill in your values. Never commit .env.local.
#
# Variables marked REQUIRED must be set or the bot will refuse to start.
# Variables marked RECOMMENDED degrade specific features when missing.
# Variables marked OPTIONAL only enable additional functionality.

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Telegram bot token (talk to @BotFather to create one)
TELEGRAM_BOT_TOKEN=

# 0G Galileo testnet wallet, 0x-prefixed. Fund at https://faucet.0g.ai
# Used for both 0G Compute (LLM inference) and 0G Storage (audit trail).
HAWKEYE_EVM_PRIVATE_KEY=


# ─── RECOMMENDED ─────────────────────────────────────────────────────────────

# 0G Compute / Storage RPC endpoint (defaults to Galileo testnet)
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Anthropic Claude API — fallback LLM when 0G Compute is unavailable
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# 0G Compute model + provider override (defaults shown)
OG_MODEL=qwen/qwen-2.5-7b-instruct
OG_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836

# Privy — per-user agent wallets. Without these, only external-wallet mode works.
PRIVY_APP_ID=
PRIVY_APP_SECRET=


# ─── OPTIONAL ────────────────────────────────────────────────────────────────

# Uniswap Trading API — fallback DEX quotes when DexScreener is unavailable
UNISWAP_API_KEY=

# GoPlus Security API — token safety scanning (https://docs.gopluslabs.io)
GOPLUS_API_KEY=
GOPLUS_API_SECRET=

# KeeperHub — MEV-protected EVM transaction submission (https://app.keeperhub.com)
KH_API_KEY=
