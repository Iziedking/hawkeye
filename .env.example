# Copy to .env.local and fill in your values. Never commit .env.local.

# GoPlus Security API (https://docs.gopluslabs.io)
GOPLUS_API_KEY=
GOPLUS_API_SECRET=

# 0G Galileo testnet wallet (0x-prefixed). Fund at https://faucet.0g.ai
HAWKEYE_EVM_PRIVATE_KEY=

# KeeperHub (https://app.keeperhub.com)
KH_API_KEY=

# OpenClaw gateway token. Auto-read from ~/.openclaw/openclaw.json if unset
OPENCLAW_GATEWAY_TOKEN=

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenRouter LLM (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# EVM RPCs — Ankr primary (https://ankr.com)
# Override per-chain with EVM_RPC_<CHAIN> (e.g. EVM_RPC_BASE, EVM_RPC_ARBITRUM)
# Public fallbacks are hardcoded in src/shared/evm-chains.ts
EVM_RPC_ETHEREUM=https://rpc.ankr.com/eth
EVM_RPC_BASE=https://rpc.ankr.com/base
EVM_RPC_POLYGON=https://rpc.ankr.com/polygon
EVM_RPC_ARBITRUM=https://rpc.ankr.com/arbitrum
EVM_RPC_OPTIMISM=https://rpc.ankr.com/optimism
EVM_RPC_BSC=https://rpc.ankr.com/bsc
