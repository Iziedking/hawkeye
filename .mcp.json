{
  "mcpServers": {
    "openclaw-docs": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "tsx",
        "src/tools/openclaw-docs-mcp/index.ts"
      ]
    },
    "coingecko": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-remote@latest",
        "https://mcp.api.coingecko.com/mcp"
      ]
    },
    "dexscreener": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "tsx",
        "src/tools/dexscreener-mcp/index.ts"
      ]
    },
    "goplus": {
      "command": "cmd",
      "args": [
        "/c",
        "node",
        "src/tools/goplus-mcp-launcher.mjs"
      ]
    },
    "gensyn-axl": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "tsx",
        "src/tools/gensyn-axl-mcp/index.ts"
      ]
    }
  }
}