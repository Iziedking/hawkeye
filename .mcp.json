{
  "mcpServers": {
    "openclaw-docs": {
      "command": "npx",
      "args": ["tsx", "src/tools/openclaw-docs-mcp/index.ts"]
    },
    "coingecko": {
      "command": "npx",
      "args": ["-y", "mcp-remote@latest", "https://mcp.api.coingecko.com/mcp"]
    },
    "dexscreener": {
      "command": "npx",
      "args": ["tsx", "src/tools/dexscreener-mcp/index.ts"]
    },
    "goplus": {
      "command": "node",
      "args": ["src/tools/goplus-mcp-launcher.mjs"]
    },
    "gensyn-axl": {
      "command": "npx",
      "args": ["tsx", "src/tools/gensyn-axl-mcp/index.ts"]
    },
    "keeperhub": {
      "command": "npx",
      "args": ["-y", "mcp-remote@latest", "https://app.keeperhub.com/mcp"]
    }
  }
}
